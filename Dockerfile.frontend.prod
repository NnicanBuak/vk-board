FROM node:20-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
ARG VITE_API_URL=/api
ARG VITE_VK_APP_ID
RUN npm run build

FROM nginx:alpine
COPY --from=builder /app/dist /usr/share/nginx/html
# nginx:alpine automatically runs envsubst on *.conf.template → /etc/nginx/conf.d/
COPY nginx/nginx.conf.template /etc/nginx/templates/default.conf.template
EXPOSE 80 443
