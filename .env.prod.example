# Copy to .env.prod on the server and fill in real values
# Path: /opt/vk-board/.env.prod

GITHUB_REPO=your-github-username/vk-mini-app
IMAGE_TAG=latest

DOMAIN=your-domain.com

POSTGRES_USER=boarduser
POSTGRES_PASSWORD=your-secure-db-password
POSTGRES_DB=board_for_chat

JWT_SECRET=your-jwt-secret-at-least-32-characters
VK_SECRET=your-vk-app-secret-key
