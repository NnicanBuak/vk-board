# ── Local dev (.env.local) ───────────────────────────────────────────
VITE_API_URL="http://localhost:3001/api"
VITE_VK_APP_ID="your-vk-app-id"
VITE_DEV_USER_ID=1          # bypass VK Bridge auth locally

# ── Vercel: Preview env (vk-mini-app-chi.vercel.app) ─────────────────
# VITE_API_URL="https://vk-board.nnican.ru/api"
# VITE_VK_APP_ID="your-vk-app-id"
# VITE_DEV_USER_ID=1

# ── Vercel: Production env (vk-board.nnican.ru) ───────────────────────
# VITE_API_URL="https://vk-board.nnican.ru/api"
# VITE_VK_APP_ID="your-vk-app-id"
# (no VITE_DEV_USER_ID)

# ── Backend on VPS (server/.env) ─────────────────────────────────────
JWT_SECRET="min-32-chars-secret-key-change-me"
VK_SECRET="your-vk-service-key"
